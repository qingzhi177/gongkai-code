      "reasoningSegmentsJson": "{\"v\":2,\"segments\":[{\"text\":\"Compatibility reasoning summary.\",\"startAt\":\"2026-07-05T17:41:39.435972\",\"finishedAt\":\"2026-07-05T17:41:39.439665\",\"expanded\":false,\"toolStartIndex\":0}],\"contentSplits\":{\"offsets\":[0],\"reasoningCounts\":[1],\"toolCounts\":[0]}}",
